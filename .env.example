# Copy this file to .env and add your key:   cp .env.example .env
# The .env file is git-ignored and must never be committed.

# --- Simple path (recommended for running locally) ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# --- Alternative: Vertex AI (for Google Cloud deployment) ---
# To use a GCP project instead of an AI Studio key, comment out the
# GEMINI_API_KEY line above and uncomment the three lines below.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
